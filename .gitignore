# ---- data/ ------------------------------------------------------------------
# The data/ directory structure and .md files are git-tracked.
# Actual data files (R objects, matrices, images, pipeline outputs) are ignored.
data/**/*.rds
data/**/*.h5
data/**/*.loom
data/**/*.zarr.zip
data/**/*.tif
data/**/*.tiff
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.html
data/**/*.csv
data/**/*.json
data/**/*.xenium
data/**/*.gz
data/**/*.tar

# ---- figs/ ------------------------------------------------------------------
# Directory structure and README.md files are git-tracked.
# Actual figure files are ignored by extension.
figs/**/*.pdf
figs/**/*.jpg
figs/**/*.jpeg
figs/**/*.png
figs/**/*.svg
figs/**/*.tif
figs/**/*.tiff
figs/**/*.eps
figs/**/*.html
figs/**/*.csv

# ---- R artifacts ------------------------------------------------------------
.Rproj.user/
.Rhistory
.Rdata
.RData
.Ruserdata
*.Rproj

# ---- OS / editor artifacts --------------------------------------------------
.DS_Store
*~
*.swp

# ---- Python / notebook artifacts --------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/

# ---- Logs -------------------------------------------------------------------
*.log
