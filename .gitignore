remove_before_submission/

# ---- data/ ------------------------------------------------------------------
# The data/ directory structure and .md files are git-tracked.
# Actual data files (R objects, matrices, images, pipeline outputs) are ignored.
data/*
!data/**/*.md

# ---- figs/ ------------------------------------------------------------------
# Directory structure and README.md files are git-tracked.
# Actual figure files are ignored by extension.
figs/**/*.pdf
figs/**/*.jpg
figs/**/*.jpeg
figs/**/*.png
figs/**/*.svg
figs/**/*.tif
figs/**/*.tiff
figs/**/*.eps
figs/**/*.html
figs/**/*.csv

# ---- R artifacts ------------------------------------------------------------
.Rproj.user/
.Rhistory
.Rdata
.RData
.Ruserdata
*.Rproj
# renv: project library under environment/ only (lockfile: environment/renv.lock)
/renv
/renv.lock
environment/renv/library/
environment/renv/staging/
environment/renv/cache/
environment/renv/index/
environment/renv/python/
environment/renv/local/
environment/renv/cellar/
.Rprofile
.Renviron

# ---- OS / editor artifacts --------------------------------------------------
.DS_Store
*~
*.swp

# ---- Python vendors ---------------------------------------------------------
environment/vendor/

# ---- Python / notebook artifacts --------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/

# ---- Logs -------------------------------------------------------------------
*.log
